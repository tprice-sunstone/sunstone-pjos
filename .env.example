# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Square
SQUARE_APPLICATION_ID=your_square_app_id
SQUARE_APPLICATION_SECRET=your_square_app_secret
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_ENVIRONMENT=sandbox
SQUARE_WEBHOOK_SIGNATURE_KEY=your_webhook_sig

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable
STRIPE_WEBHOOK_SECRET=your_webhook_secret

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
# Messaging Service SID for A2P 10DLC compliance (Twilio Console → Messaging → Services)
TWILIO_MESSAGING_SERVICE_SID=

# Resend
RESEND_API_KEY=your_resend_key
RESEND_FROM_EMAIL=noreply@sunstone.app

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Sunstone PJOS

# Demo System (Tradeshow)
DEMO_NEWBIE_EMAIL=demo.luna@sunstonestudio.app
DEMO_NEWBIE_PASSWORD=DemoLuna2026!
DEMO_MID_EMAIL=demo.spark@sunstonestudio.app
